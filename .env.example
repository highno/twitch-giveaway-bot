MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=bot
MYSQL_PASSWORD=botpass
MYSQL_DB=twitch_giveaway

TWITCH_CLIENT_ID=...
TWITCH_CLIENT_SECRET=...

# User token + refresh token for EventSub subscriptions
TWITCH_USER_ACCESS_TOKEN=...
TWITCH_USER_REFRESH_TOKEN=...

# Twitch channels (logins) to monitor
CHANNEL_LOGINS=channel1,channel2

# Bot IRC identity/token
BOT_NICK=yourbotlogin
IRC_OAUTH_TOKEN=oauth:...

# One-time opt-in keyword (global across all channels)
OPTIN_CODEWORD=ticketme

# Chat commands
COMMAND_TICKET_COUNT=Anzahl_Tickets
COMMAND_PAUSE_PARTICIPATION=Ausstieg
COMMAND_DELETE_USER_DATA=Ausstieg_Loeschen

# Configurable chat responses
RESPONSE_OPTIN_SUCCESS=@{user} Du nimmst jetzt an der Verlosung teil. Mit '{ticket_count_command}' siehst du jederzeit deinen Stand (aktuell: {tickets}).
RESPONSE_NOT_REGISTERED=@{user} Du bist noch nicht registriert. Schreibe '{optin_codeword}', um teilzunehmen.
RESPONSE_TICKET_COUNT=@{user} Du hast aktuell {tickets} Ticket(s) im Lostopf.
RESPONSE_PAUSE_SUCCESS=@{user} Du bist vorübergehend aus dem Wettbewerb ausgestiegen. Mit '{delete_user_data_command}' kannst du anschließend alle deine Daten löschen.
RESPONSE_PAUSE_NOT_ACTIVE=@{user} Du bist derzeit nicht aktiv im Wettbewerb.
RESPONSE_DELETE_SUCCESS=@{user} Deine gespeicherten Daten wurden gelöscht.
RESPONSE_DELETE_REQUIRES_PAUSE=@{user} Das Löschen ist erst nach einem vorübergehenden Ausstieg mit '{pause_command}' möglich.

# Ticket interval (minutes)
TICKET_INTERVAL_MINUTES=10

# Moderation/bot protection
IGNORED_LOGINS=streamelements,nightbot,moobot,streamlabs,wizebot,commanderroot
IGNORE_VERIFIED_BOTS=1
